---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import TwoColumnLayout from "../../layouts/TwoColumnLayout.astro";
import PostCard from "../../components/PostCard.astro";
import GalleryGrid from "../../components/GalleryGrid.astro";

const layerDisplayNames: Record<string, string> = {
  fashion: "Fashion / Art",
  commerce: "Commerce",
  infrastructure: "Infrastructure",
  governance: "Governance",
  culture: "Culture",
  nature: "Nature",
};

const allLayers = Object.keys(layerDisplayNames);

export async function getStaticPaths() {
  return [
    "fashion",
    "commerce",
    "infrastructure",
    "governance",
    "culture",
    "nature",
  ].map((layer) => ({ params: { layer } }));
}

const { layer } = Astro.params;
const displayName = layerDisplayNames[layer!] ?? layer;

const hasLayer = (paceLayers: { layer: string; rationale: string }[]) =>
  paceLayers.some((pl) => pl.layer === layer);

const posts = (await getCollection("posts"))
  .filter((post) => !post.data.draft && hasLayer(post.data.paceLayers))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const talks = (await getCollection("talks"))
  .filter((talk) => hasLayer(talk.data.paceLayers))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const photos = (await getCollection("photos"))
  .filter((photo) => !photo.data.draft && hasLayer(photo.data.paceLayers))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout title={`Pace Layer: ${displayName}`}>
  <TwoColumnLayout>
    <h1>Pace Layer: {displayName}</h1>
    <p class="meta-text">
      Content that engages the {displayName.toLowerCase()} layer of
      <a href="/approach">the pace layers framework</a>.
    </p>

    {talks.length > 0 && (
      <section>
        <h2>Talks</h2>
        <ul>
          {talks.map((talk) => (
            <li>
              <a href={`/speaking/${talk.id}`}>{talk.data.title}</a>
              <div class="meta-text">
                {talk.data.event} · {talk.data.date.toLocaleDateString("en-US", { year: "numeric", month: "long", timeZone: "UTC" })}
              </div>
            </li>
          ))}
        </ul>
      </section>
    )}

    {posts.length > 0 && (
      <section>
        {talks.length > 0 && <h2>Posts</h2>}
        <div class="stack-spacious">
          {posts.map((post) => <PostCard post={post} />)}
        </div>
      </section>
    )}

    {photos.length > 0 && (
      <section>
        <h2>Photos</h2>
        <GalleryGrid photos={photos} compact />
      </section>
    )}

    {posts.length === 0 && talks.length === 0 && photos.length === 0 && (
      <p>No content has been annotated with this layer yet.</p>
    )}
  </TwoColumnLayout>
</BaseLayout>
