---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import TwoColumnLayout from "../../layouts/TwoColumnLayout.astro";
import PostCard from "../../components/PostCard.astro";
import GalleryGrid from "../../components/GalleryGrid.astro";

export async function getStaticPaths() {
  const posts = (await getCollection("posts")).filter((post) => !post.data.draft);
  const talks = await getCollection("talks");
  const photos = (await getCollection("photos")).filter((photo) => !photo.data.draft);
  const allTags = [
    ...posts.flatMap((p) => p.data.tags),
    ...talks.flatMap((t) => t.data.tags),
    ...photos.flatMap((p) => p.data.tags),
  ].map((t) => t.toLowerCase());
  const tags = [...new Set(allTags)];

  return tags.map((tag) => ({ params: { tag } }));
}

const { tag } = Astro.params;
const matchesTag = (tags: string[]) => tags.map((t) => t.toLowerCase()).includes(String(tag));

const posts = (await getCollection("posts"))
  .filter((post) => !post.data.draft && matchesTag(post.data.tags))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const talks = (await getCollection("talks"))
  .filter((talk) => matchesTag(talk.data.tags))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const photos = (await getCollection("photos"))
  .filter((photo) => !photo.data.draft && matchesTag(photo.data.tags))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout title={`Tag: ${tag}`}>
  <TwoColumnLayout>
    <h1>Tag: #{tag}</h1>

    {talks.length > 0 && (
      <section>
        <h2>Talks</h2>
        <ul>
          {talks.map((talk) => (
            <li>
              <a href={`/speaking/${talk.id}`}>{talk.data.title}</a>
              <div class="meta-text">
                {talk.data.event} · {talk.data.date.toLocaleDateString("en-US", { year: "numeric", month: "long", timeZone: "UTC" })}
              </div>
            </li>
          ))}
        </ul>
      </section>
    )}

    {posts.length > 0 && (
      <section>
        <h2>Posts</h2>
        <div class="stack-spacious">
          {posts.map((post) => <PostCard post={post} />)}
        </div>
      </section>
    )}

    {photos.length > 0 && (
      <section>
        <h2>Photos</h2>
        <GalleryGrid photos={photos} compact />
      </section>
    )}
  </TwoColumnLayout>
</BaseLayout>
