---
import type { CollectionEntry } from "astro:content";
import TagList from "./TagList.astro";

interface Props {
  post: CollectionEntry<"posts">;
}

const { post } = Astro.props;
const dateText = post.data.date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
  timeZone: "UTC",
});
---

<article class="post-card">
  <h2 class="post-card-title"><a href={`/posts/${post.id}`}>{post.data.title}</a></h2>
  <p class="meta-text post-card-meta">{dateText}{post.data.category && <> · <a class="category-label" href={`/category/${encodeURIComponent(post.data.category.toLowerCase())}`}>{post.data.category}</a></>}</p>
  <p>{post.data.description}</p>
  {post.data.tags.length > 0 && <TagList tags={post.data.tags} />}
</article>
