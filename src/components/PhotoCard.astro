---
import type { CollectionEntry } from "astro:content";
import TagList from "./TagList.astro";

interface Props {
  photo: CollectionEntry<"photos">;
}

const { photo } = Astro.props;
const dateText = photo.data.date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
  timeZone: "UTC",
});
---

<article class="post-card photo-card">
  <a href={`/photos/${photo.id}`} class="photo-card-image-link">
    <img
      src={photo.data.image}
      alt={photo.data.alt}
      class="photo-card-image"
      loading="lazy"
    />
  </a>
  <h2 class="post-card-title"><a href={`/photos/${photo.id}`}>{photo.data.title}</a></h2>
  <p class="meta-text post-card-meta">
    {dateText}
    {photo.data.location && <> · {photo.data.location}</>}
    {photo.data.category && <> · <a class="category-label" href={`/category/${encodeURIComponent(photo.data.category.toLowerCase())}`}>{photo.data.category}</a></>}
  </p>
  <p>{photo.data.description}</p>
  {photo.data.tags.length > 0 && <TagList tags={photo.data.tags} />}
</article>
