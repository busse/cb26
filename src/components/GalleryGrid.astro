---
import type { CollectionEntry } from "astro:content";

interface Props {
  photos: CollectionEntry<"photos">[];
  compact?: boolean;
}

const { photos, compact = false } = Astro.props;
---

<div class={`gallery-grid ${compact ? "gallery-grid--compact" : ""}`}>
  {photos.map((photo) => (
    <a href={`/photos/${photo.id}`} class="gallery-cell">
      <img
        src={photo.data.image}
        alt={photo.data.alt}
        class="gallery-cell-image"
        loading="lazy"
      />
      <div class="gallery-cell-caption">
        <span class="gallery-cell-title">{photo.data.title}</span>
        <span class="gallery-cell-date">
          {photo.data.date.toLocaleDateString("en-US", { year: "numeric", month: "short", timeZone: "UTC" })}
        </span>
      </div>
    </a>
  ))}
</div>
