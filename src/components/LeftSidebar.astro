---
import { getCollection } from "astro:content";
import { siteConfig } from "../data/site";

const posts = (await getCollection("posts"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const categories = [...new Set(
  posts
    .map((post) => post.data.category)
    .filter((c): c is string => Boolean(c))
    .map((c) => c.toLowerCase()),
)].sort();

const now = new Date();
const today = new Date(now.getFullYear(), now.getMonth(), now.getDate());

const allTalks = (await getCollection("talks")).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);

const upcomingTalks = allTalks.filter((t) => t.data.date >= today);
const recentTalks = allTalks.filter((t) => t.data.date < today).slice(0, 5);
---

<aside class="left-rail">
  <div class="sidebar-block">
    <p class="section-label">About</p>
    <p class="lead-text">
      I use creativity to guide leaders through complex enterprise change.
      Currently at SingleStone and Eszett. Based in {siteConfig.location}.
    </p>
  </div>

  {categories.length > 0 && (
    <div class="sidebar-block">
      <p class="section-label">Categories</p>
      <ul class="category-list">
        {categories.map((cat) => <li><a href={`/category/${encodeURIComponent(cat)}`}>{cat}</a></li>)}
      </ul>
    </div>
  )}

  {upcomingTalks.length > 0 && (
    <div class="sidebar-block sidebar-talks">
      <p class="section-label">Upcoming Talks</p>
      <ul class="talks-list">
        {upcomingTalks.map((talk) => (
          <li>
            <a href={`/speaking/${talk.id}`}>{talk.data.title}</a>
            <span class="talk-detail">{talk.data.event} · {talk.data.date.toLocaleDateString("en-US", { month: "short", day: "numeric", timeZone: "UTC" })}</span>
          </li>
        ))}
      </ul>
    </div>
  )}

  {recentTalks.length > 0 && (
    <div class="sidebar-block sidebar-talks">
      <p class="section-label">Recent Talks</p>
      <ul class="talks-list">
        {recentTalks.map((talk) => (
          <li>
            <a href={`/speaking/${talk.id}`}>{talk.data.title}</a>
            <span class="talk-detail">{talk.data.event} · {talk.data.date.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric", timeZone: "UTC" })}</span>
          </li>
        ))}
      </ul>
    </div>
  )}
</aside>
