---
import { getCollection } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';
import ScreenshotGallery from '../../components/ScreenshotGallery.astro';
import { fetchRepo, type GitHubRepo } from '../../lib/github';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await project.render();

// Fetch GitHub stats if this is a GitHub project
let githubStats: GitHubRepo | null = null;
if (project.data.github_repo) {
  const [owner, repo] = project.data.github_repo.split('/');
  if (owner && repo) {
    githubStats = await fetchRepo(owner, repo);
  }
}

// Status labels and colors
const statusLabels: Record<string, string> = {
  active: 'Active',
  archived: 'Archived',
  concept: 'Concept',
  wip: 'Work in Progress',
};

const statusColors: Record<string, string> = {
  active: 'var(--color-accent)',
  archived: 'var(--color-ink-muted)',
  concept: '#8b5cf6',
  wip: '#f59e0b',
};

// Type labels
const typeLabels: Record<string, string> = {
  career: 'Career Project',
  github: 'Open Source',
  community: 'Community',
  consulting: 'Consulting',
};

// Format dates
const startDate = project.data.date_start.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
});
const endDate = project.data.date_end 
  ? project.data.date_end.toLocaleDateString('en-US', { year: 'numeric', month: 'short' })
  : 'Present';
---

<PageLayout 
  title={project.data.title}
  description={project.data.description}
>
  <article class="project-detail">
    <header class="project-header">
      <div class="project-header-top">
        <span class="kicker">{typeLabels[project.data.type]} · {project.data.category}</span>
        {project.data.status && project.data.status !== 'active' && (
          <span 
            class="status-badge" 
            style={`--status-color: ${statusColors[project.data.status]}`}
          >
            {statusLabels[project.data.status]}
          </span>
        )}
      </div>
      <h1>{project.data.title}</h1>
      <p class="lead">{project.data.description}</p>
    </header>
    
    <!-- Project metadata block -->
    <div class="project-meta-block">
      <dl class="project-details">
        <div class="project-detail">
          <dt>Timeline</dt>
          <dd>{startDate} — {endDate}</dd>
        </div>
        
        {project.data.company && (
          <div class="project-detail">
            <dt>Company</dt>
            <dd>{project.data.company}</dd>
          </div>
        )}
        
        {project.data.role && (
          <div class="project-detail">
            <dt>Role</dt>
            <dd>{project.data.role}</dd>
          </div>
        )}
        
        {githubStats && (
          <>
            <div class="project-detail">
              <dt>Stars</dt>
              <dd>{githubStats.stars}</dd>
            </div>
            {githubStats.forks > 0 && (
              <div class="project-detail">
                <dt>Forks</dt>
                <dd>{githubStats.forks}</dd>
              </div>
            )}
            {githubStats.language && (
              <div class="project-detail">
                <dt>Language</dt>
                <dd>{githubStats.language}</dd>
              </div>
            )}
          </>
        )}
      </dl>
      
      <!-- Tech stack -->
      {project.data.tech_stack && project.data.tech_stack.length > 0 && (
        <div class="tech-stack">
          <span class="tech-stack-label">Tech Stack</span>
          <div class="cluster">
            {project.data.tech_stack.map((tech) => (
              <span class="tag">{tech}</span>
            ))}
          </div>
        </div>
      )}
    </div>
    
    <!-- Action buttons -->
    <div class="project-actions cluster">
      {project.data.url && (
        <a href={project.data.url} class="btn">
          Visit Project →
        </a>
      )}
      {project.data.demo_url && (
        <a href={project.data.demo_url} class="btn">
          Live Demo →
        </a>
      )}
      {project.data.github_repo && (
        <a href={`https://github.com/${project.data.github_repo}`} class="btn">
          GitHub →
        </a>
      )}
    </div>
    
    <!-- Screenshot gallery -->
    {project.data.screenshots && project.data.screenshots.length > 0 && (
      <ScreenshotGallery 
        screenshots={project.data.screenshots} 
        projectSlug={project.slug} 
      />
    )}
    
    <!-- Main content -->
    <div class="project-body">
      <Content />
    </div>
    
    <!-- Highlights -->
    {project.data.highlights && project.data.highlights.length > 0 && (
      <section class="project-highlights">
        <h2>Highlights</h2>
        <ul>
          {project.data.highlights.map((highlight) => (
            <li>{highlight}</li>
          ))}
        </ul>
      </section>
    )}
    
    <!-- Lessons learned / Retrospective -->
    {project.data.lessons && (
      <section class="project-lessons">
        <h2>Lessons Learned</h2>
        <div class="lessons-content">
          <p>{project.data.lessons}</p>
        </div>
      </section>
    )}
    
    <!-- Back link -->
    <p class="back-link">
      <a href="/projects/">← Back to Projects</a>
    </p>
  </article>
</PageLayout>

<style>
  .project-detail {
    max-width: 50rem;
  }
  
  .project-header {
    margin-bottom: var(--space-8);
    padding-bottom: var(--space-6);
    border-bottom: var(--border-thin);
  }
  
  .project-header-top {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    flex-wrap: wrap;
    margin-bottom: var(--space-2);
  }
  
  .status-badge {
    font-size: var(--font-size-xs);
    font-weight: 600;
    padding: var(--space-1) var(--space-2);
    background: var(--status-color, var(--color-ink-muted));
    color: white;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  
  .project-header h1 {
    margin-top: var(--space-2);
    margin-bottom: var(--space-4);
  }
  
  .project-meta-block {
    background: var(--color-paper-dark);
    padding: var(--space-5);
    margin-bottom: var(--space-6);
    border-left: var(--border-accent);
  }
  
  .project-details {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(10rem, 1fr));
    gap: var(--space-4);
  }
  
  .project-detail dt {
    font-size: var(--font-size-xs);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-ink-muted);
    margin-bottom: var(--space-1);
  }
  
  .project-detail dd {
    font-size: var(--font-size-sm);
    color: var(--color-ink);
  }
  
  .tech-stack {
    margin-top: var(--space-4);
    padding-top: var(--space-4);
    border-top: var(--border-thin);
  }
  
  .tech-stack-label {
    display: block;
    font-size: var(--font-size-xs);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-ink-muted);
    margin-bottom: var(--space-2);
  }
  
  .project-actions {
    margin-bottom: var(--space-6);
    gap: var(--space-3);
  }
  
  .project-body {
    margin-bottom: var(--space-8);
  }
  
  .project-body :global(h2) {
    margin-top: var(--space-8);
    padding-top: var(--space-4);
    border-top: var(--border-thin);
  }
  
  .project-body :global(h2:first-child) {
    margin-top: 0;
    padding-top: 0;
    border-top: none;
  }
  
  .project-highlights,
  .project-lessons {
    margin-top: var(--space-8);
    padding-top: var(--space-6);
    border-top: var(--border-thin);
  }
  
  .project-highlights h2,
  .project-lessons h2 {
    font-size: var(--font-size-lg);
    margin-bottom: var(--space-4);
  }
  
  .project-highlights ul {
    list-style: none;
    padding: 0;
  }
  
  .project-highlights li {
    padding: var(--space-2) 0;
    padding-left: var(--space-4);
    border-left: 2px solid var(--color-accent);
    font-size: var(--font-size-sm);
    margin-bottom: var(--space-2);
  }
  
  .lessons-content {
    background: var(--color-paper-dark);
    padding: var(--space-4);
    font-size: var(--font-size-sm);
    color: var(--color-ink-light);
    font-style: italic;
    border-left: var(--border-accent);
  }
  
  .lessons-content p {
    margin: 0;
  }
  
  .back-link {
    margin-top: var(--space-10);
  }
</style>
